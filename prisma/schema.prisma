generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VisitStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
}

model Patient {
  id        Int      @id @default(autoincrement())
  fullName  String
  age       Int
  gender    String
  phone     String?
  visits    Visit[]
  createdAt DateTime @default(now())
}

model Visit {
  id          Int         @id @default(autoincrement())
  patientId   Int
  queueNumber Int
  symptoms    String
  status      VisitStatus @default(WAITING)

  patient     Patient     @relation(fields: [patientId], references: [id])

  createdAt   DateTime    @default(now())
}